# Environment Variables for Frontend
# Copy this file to .env and replace YOUR_API_KEY_HERE with your actual API key

# Google OAuth Client ID (Required for Google Sign-In)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Backend API URL (automatically detected if not set)
# VITE_API_URL=http://localhost:3001
# For production deployment (Netlify/Vercel):
# VITE_API_URL=https://your-backend-domain.com

# Choose ONE of the following AI APIs for Chatbot:

# Option 1: Groq (Recommended - Free & Fast)
# Get API key from: https://console.groq.com/keys
VITE_GROQ_API_KEY=YOUR_API_KEY_HERE

# Option 2: OpenAI (Requires payment but $5 free credit for new users)
# Get API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=YOUR_API_KEY_HERE

# Option 3: Hugging Face (Free)
# Get API key from: https://huggingface.co/settings/tokens
VITE_HUGGINGFACE_API_KEY=YOUR_API_KEY_HERE
